<root>
	<styles>
		<include src="file://{resources}/styles/custom_game/manta.css" />
	</styles>
	<scripts>
		<include src="file://{resources}/scripts/custom_game/manta.js" />
	</scripts>
	<Panel hittest="false" class="Main" >
		<Button class="volvoButton" id="btnTest" onactivate="endCustomTraining()">
			<Label text="#trainingEnd"/>
		</Button>
		<Button class="volvoButton" id="btnRetry" onactivate="retryAimTraining()">
			<Label text="Retry"/>
		</Button>
		<!-- <Button class="volvoButton" id="btnTest2" onactivate="onBtnTestClick3('myArgument')">
			<Label text="sosi pisos"/>   
		</Button> -->
<!-- 		<Panel id="zalupa" class="container">
			<Label text="Test"/>
		</Panel> -->
		<Label hittest="false" class="scoreInfo" id="textTest" text="Score: 0"/>
		<Label hittest="false" class="scoreInfo" id="aimCombo" text="x1"/>
		<Label hittest="false" class="scoreInfo" id="livesLeft" text="Time: 40"/>
		<Label hittest="false" class="scoreInfo" id="avgTime" text="Avg. time:"/>
		<Panel hittest="false" id="testskill" class="Skills">
			<DOTAAbilityImage id="myability" abilityname="lina_light_strike_array" />
		</Panel>
		<Panel id="Timing">
			<Panel id="TimeBar" class="Bar">
				<Panel hittest="false" class="hui" id="spellBar">
				</Panel>
				<Panel hittest="false" class="hui" id="manta">
				</Panel>
			</Panel>
			<Label hittest="false" id="cursor"/>
		</Panel>
		<Panel id="mantaNotify">
			<Label hittest="false" id="notify" text="Good!"/>
			<Label hittest="false" id="desc" text="Good!"/>
		</Panel>
		<Panel style="visibility:collapse;" id="mantaLives">
			<Panel class="mantaLive">
			</Panel>
			<Panel class="mantaLive">
			</Panel>
			<Panel class="mantaLive">
			</Panel>
		</Panel>
		<Panel id="morphHelper">
			<Label id="morphTimer" class="helperText" text="0.000"/>
			<Label id="morphHelperText" class="helperText" text="Use morph on enemy and spend all spells as fast as you can."/>
			<Panel id="morphSpellContainer">
				<Panel class="morphSpell">
					
				</Panel>
			</Panel>
		</Panel>
	</Panel>
</root>